# MinerU API Token — get from https://mineru.net/apiManage/token
MINERU_API_TOKEN=your_token_here

# LanceDB data directory (default: ~/.mapce/data)
MAPCE_DATA_DIR=~/.mapce/data

# Embedding model (default: intfloat/multilingual-e5-large)
MAPCE_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Log level
MAPCE_LOG_LEVEL=INFO

# ---- Network proxy (optional, required for mainland China) ----
# httpx (MinerU API) and git clone will use these automatically.
# Uncomment and fill in your proxy address.
# http_proxy=http://127.0.0.1:9674
# https_proxy=http://127.0.0.1:9674
# all_proxy=socks5://127.0.0.1:9674
